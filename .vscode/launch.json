{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch API Server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/main.go",
      "args": [
        "-config",
        "${workspaceFolder}/backend/configs/config.yaml"
      ],
      "env": {},
      "console": "integratedTerminal",
      "showLog": true
    },
    {
      "name": "Launch Collector",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/collector/main.go",
      "args": [
        "-config",
        "${workspaceFolder}/backend/configs/config.yaml"
      ],
      "env": {},
      "console": "integratedTerminal",
      "showLog": true
    },
    {
      "name": "Next.js: Frontend",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Next.js: Browser",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ]
}